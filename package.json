{
  "name": "simple-3d-modeling-mcp",
  "version": "1.2.4",
  "description": "MCP server that connects Claude (and other AI assistants) to OpenSCAD for 3D modeling",
  "type": "module",
  "bin": {
    "simple-3d-modeling-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "openscad",
    "3d-modeling",
    "cad",
    "model-context-protocol",
    "claude",
    "ai"
  ],
  "author": "",
  "license": "GPL-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "openscad-wasm": "^0.0.4",
    "sharp": "^0.34.5",
    "three": "^0.183.2",
    "upng-js": "^2.1.0",
    "ws": "^8.19.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/three": "^0.183.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
